# Environment Configuration for Agentic Research Assistant

# ===== API Configuration =====
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ===== LLM Configuration =====
OPENAI_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000
REQUEST_TIMEOUT_SECONDS=30

# ===== Vector Database =====
PINECONE_API_KEY=your-pinecone-key
PINECONE_ENVIRONMENT=us-west-2
PINECONE_INDEX=research-assistant

# ===== Database =====
DATABASE_URL=postgresql://research_user:research_pass@localhost:5432/research_db

# ===== Redis Cache =====
REDIS_URL=redis://localhost:6379
CACHE_TTL_MINUTES=60

# ===== Research Settings =====
MAX_SEARCH_RESULTS=10
FACT_CHECK_ENABLED=true
MAX_RESEARCH_DEPTH=detailed

# ===== Web Search API =====
SERPER_API_KEY=your-serper-key
GOOGLE_SEARCH_API_KEY=your-google-search-key

# ===== Monitoring =====
ENABLE_MONITORING=true
PROMETHEUS_PORT=9090

# ===== Rate Limiting =====
RATE_LIMIT_PER_MINUTE=60

# ===== Task Settings =====
TASK_TIMEOUT_SECONDS=300
MAX_CONCURRENT_TASKS=10

# ===== LangSmith (Optional) =====
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agentic-research-assistant
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-key
